{
  "name": "iso-pro-mobile",
  "version": "1.0.22",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:phone": "expo start --lan --clear --port 8082",
    "start:tunnel": "expo start --tunnel --clear --port 8082",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "lint:fix": "expo lint --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "remover-recibos": "tsx scripts/remover-recibos-atd.ts",
    "ci": "npm run typecheck && npm run test && npm run lint && npm run audit:ci",
    "audit:ci": "node scripts/npm-audit-ci.mjs",
    "generate:icon": "node scripts/generate-app-icon.cjs",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "build:android:preview": "npx eas-cli build -p android --profile preview",
    "build:android:production": "npx eas-cli build -p android --profile production",
    "build:android:local-apk": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-off-path.ps1"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "@sentry/react-native": "^6.14.0",
    "iso-pro-shared": "file:./vendor/iso-pro-shared",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true
}
